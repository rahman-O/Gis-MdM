# Server
SERVER_PORT=8080
GIN_MODE=debug

# Database (required when persistence is implemented)
DATABASE_URL=postgres://hmdm:hmdm@localhost:5432/hmdm?sslmode=disable

# JWT (auth module)
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
JWT_VALIDITY_SECONDS=86400
JWT_VALIDITY_REMEMBER_SECONDS=2592000

# Session cookie (public auth login)
SESSION_SECRET=change-me-session

# Auth options
CUSTOMER_SIGNUP=false
EMAIL_CONFIGURED=false
TRANSMIT_PASSWORD=false
BASE_URL=http://localhost:8080

# Swagger UI at /swagger/index.html
SWAGGER_ENABLED=true

# IP allowlists (comma-separated CIDRs or IPs; empty = allow all)
PUBLIC_IP_ALLOWLIST=
PRIVATE_IP_ALLOWLIST=

# Module feature flags (auth stack)
MODULE_AUTH_ENABLED=true
MODULE_PASSWORDRESET_ENABLED=true
MODULE_SIGNUP_ENABLED=false

# Files (future modules)
FILES_DIRECTORY=/var/lib/hmdm/files
