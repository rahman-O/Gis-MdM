# Server
SERVER_PORT=8080
GIN_MODE=debug

# Database (required when persistence is implemented)
DATABASE_URL=postgres://hmdm:hmdm@localhost:5432/hmdm?sslmode=disable

# JWT (auth module)
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
JWT_VALIDITY_SECONDS=86400
JWT_VALIDITY_REMEMBER_SECONDS=2592000

# Session cookie (public auth login)
SESSION_SECRET=change-me-session

# Auth options
CUSTOMER_SIGNUP=false
EMAIL_CONFIGURED=false
TRANSMIT_PASSWORD=false
BASE_URL=http://localhost:8080

# Swagger UI at /swagger/index.html
SWAGGER_ENABLED=true

# IP allowlists (comma-separated CIDRs or IPs; empty = allow all)
PUBLIC_IP_ALLOWLIST=
PRIVATE_IP_ALLOWLIST=

# Module feature flags (auth stack)
MODULE_AUTH_ENABLED=true
MODULE_PASSWORDRESET_ENABLED=true
MODULE_SIGNUP_ENABLED=false

# Files / icons / public API (Phase 6)
# Local dev: ./data/files (created by scripts/dev.sh). Production: /var/lib/hmdm/files
FILES_DIRECTORY=./data/files
HASH_SECRET=changeme-C3z9vi54
MODULE_FILES_ENABLED=true
MODULE_ICONS_ENABLED=true
MODULE_PUBLICAPI_ENABLED=true
REBRANDING_NAME=Headwind MDM
REBRANDING_LOGO=
REBRANDING_VENDOR_NAME=
REBRANDING_VENDOR_LINK=
REBRANDING_SIGNUP_LINK=
REBRANDING_TERMS_LINK=

# Phase 7 — sync, push, notifications, updates, qrcode
SECURE_ENROLLMENT=false
PREVENT_DUPLICATE_ENROLLMENT=false
POLLING_TIMEOUT_MS=60000
MODULE_SYNC_ENABLED=true
MODULE_PUSH_ENABLED=true
MODULE_NOTIFICATIONS_ENABLED=true
MODULE_UPDATES_ENABLED=true
MODULE_QRCODE_ENABLED=true
REBRANDING_MOBILE_NAME=
UPDATE_MANIFEST_URL=https://h-mdm.com/files/hmdm_update_manifest.txt
